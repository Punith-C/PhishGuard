<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_deep">

    <include layout="@layout/header_phishguard" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="28dp">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:tabMode="fixed"
            app:tabIndicatorColor="@color/cyan_primary"
            app:tabIndicatorHeight="3dp"
            app:tabTextColor="@color/text_secondary"
            app:tabSelectedTextColor="@color/cyan_primary"
            app:tabTextAppearance="@style/TextAppearance.Design.Tab"
            android:layout_marginBottom="20dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="100dp"
            android:overScrollMode="never" />

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="No domains blocked this session"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="60dp"
            android:visibility="gone" />

    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/danger_bg"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStopVpn"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Stop VPN Protection"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textColor="@color/danger"
            app:icon="@drawable/ic_stop"
            app:iconTint="@color/danger"
            app:iconGravity="start"
            app:iconSize="20dp"
            app:iconPadding="12dp"
            app:strokeColor="@color/danger"
            app:strokeWidth="1.5dp"
            app:cornerRadius="16dp"
            android:layout_margin="20dp" />

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
