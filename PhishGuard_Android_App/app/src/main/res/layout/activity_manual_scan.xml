<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_deep">

    <include layout="@layout/header_phishguard"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="32dp">

            <TextView
                android:text="URL Scanner"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:letterSpacing="0.01"
                android:layout_marginBottom="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Check any website for phishing threats"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="24dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bg_surface"
                app:strokeColor="@color/stroke"
                app:strokeWidth="1dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:text="Enter URL to analyze"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_hint"
                        android:textAllCaps="true"
                        android:letterSpacing="0.07"
                        android:layout_marginBottom="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/stroke_active"
                        app:boxStrokeWidth="1dp"
                        app:hintTextColor="@color/text_hint"
                        app:endIconMode="clear_text"
                        app:endIconTint="@color/text_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etUrl"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:hint="https://example.com"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:inputType="textUri"/>
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScan"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Scan for Phishing"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:letterSpacing="0.01"
                android:textColor="@color/text_on_primary"
                app:backgroundTint="@color/cyan_primary"
                app:cornerRadius="16dp"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressIndicator"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:indeterminate="true"
                android:visibility="gone"
                app:indicatorColor="@color/cyan_primary"
                app:trackColor="@color/stroke"
                app:trackCornerRadius="2dp"
                android:layout_marginBottom="20dp"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bg_surface"
                app:strokeColor="@color/stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="32dp"
                    android:paddingBottom="32dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardResultIcon"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="@color/bg_surface_2"
                        app:cardElevation="0dp"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:id="@+id/imgResult"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_search"/>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvResultTitle"
                        android:text="Ready to Scan"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/tvResultSubtitle"
                        android:text="Enter a URL above and tap Scan to check for phishing threats"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center"
                        android:lineSpacingExtra="3dp"
                        android:layout_marginBottom="0dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <LinearLayout
                        android:id="@+id/layoutDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginTop="24dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/stroke"
                            android:layout_marginBottom="20dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="14dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_domain"
                                android:layout_marginEnd="10dp"
                                app:tint="@color/text_hint"/>

                            <TextView
                                android:text="Domain"
                                android:textSize="13sp"
                                android:textColor="@color/text_hint"
                                android:layout_width="90dp"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:id="@+id/tvDomain"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_threats"
                                android:layout_marginEnd="10dp"
                                app:tint="@color/text_hint"/>

                            <TextView
                                android:text="Risk Score"
                                android:textSize="13sp"
                                android:textColor="@color/text_hint"
                                android:layout_width="90dp"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:id="@+id/tvScore"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"/>
                        </LinearLayout>

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressScore"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:progress="0"
                            android:max="100"
                            android:layout_marginBottom="16dp"
                            android:layout_marginStart="28dp"
                            app:indicatorColor="@color/cyan_primary"
                            app:trackColor="@color/stroke"
                            app:trackCornerRadius="3dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="20dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_timer"
                                android:layout_marginEnd="10dp"
                                app:tint="@color/text_hint"/>

                            <TextView
                                android:text="Scan Time"
                                android:textSize="13sp"
                                android:textColor="@color/text_hint"
                                android:layout_width="90dp"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:id="@+id/tvTime"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"/>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/stroke"
                            android:layout_marginBottom="16dp"/>

                        <TextView
                            android:text="ANALYSIS DETAILS"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_hint"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="10dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/bg_surface_2"
                            app:strokeWidth="0dp">

                            <TextView
                                android:id="@+id/tvReason"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="14dp"
                                android:textSize="13sp"
                                android:textColor="@color/text_secondary"
                                android:lineSpacingExtra="4dp"/>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>