<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_deep">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="48dp"
        android:paddingBottom="40dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/danger_bg"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/danger"
            app:strokeWidth="1dp">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                android:scaleType="centerInside"
                android:src="@drawable/ic_stop" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phishing Site Blocked"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/danger"
            android:textAlignment="center"
            android:letterSpacing="0.01"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PhishGuard blocked access to a dangerous website"
            android:textSize="15sp"
            android:textColor="@color/text_secondary"
            android:textAlignment="center"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/danger_bg"
            app:strokeColor="@color/danger"
            app:strokeWidth="1dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_warning"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tvWarningDomain"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/danger"
                    android:ellipsize="middle"
                    android:maxLines="2"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_surface"
            app:strokeColor="@color/stroke"
            app:strokeWidth="1dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_threats"
                        android:layout_marginEnd="10dp"/>
                    <TextView
                        android:text="Why was this blocked?"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="This domain has been identified as a phishing threat. It may attempt to steal your passwords, banking credentials, or personal data by impersonating a legitimate service."
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoBack"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Stay Safe — Go Back"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/success"
            app:cornerRadius="16dp"
            android:layout_marginBottom="10dp"/>

        <!-- ─── ALLOW 5 MIN ─── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAllow5Min"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Allow for 5 Minutes"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:textColor="@color/warning"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/warning"
            app:strokeWidth="1dp"
            app:cornerRadius="16dp"
            android:layout_marginBottom="10dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAllowAlways"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Always Allow This Site"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:textColor="@color/text_secondary"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/stroke"
            app:strokeWidth="1dp"
            app:cornerRadius="16dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
