<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="wrap_content"

    app:cardElevation="0dp"
    app:cardCornerRadius="0dp"
    app:cardBackgroundColor="@color/bg_surface"
    app:strokeColor="@color/stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:minWidth="140dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_height="wrap_content">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="0dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                android:layout_marginEnd="8dp">

                <ImageView
                    android:layout_width="62dp"
                    android:layout_height="58dp"
                    android:layout_gravity="center"
                    android:padding="4dp"
                    android:src="@drawable/ic_app_logo"
                    android:contentDescription="App Logo"
                    android:scaleType="centerCrop"/>

            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="wrap_content"
                android:orientation="vertical"
                android:layout_height="wrap_content">

                <TextView
                    android:text="PhishGuard"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:letterSpacing="0.01"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Security Protection"
                    android:textSize="11sp"
                    android:textColor="@color/cyan_primary"
                    android:letterSpacing="0.02"
                    android:singleLine="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_pill_surface"
            android:paddingStart="10dp"
            android:paddingEnd="4dp"
            android:layout_marginEnd="8dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_person"
                android:contentDescription="User"
                app:tint="@color/text_secondary"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/headerUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="user@email.com"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:maxWidth="110dp"
                android:ellipsize="end"
                android:maxLines="1"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/headerLogout"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Logout"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:textColor="@color/danger"
            android:letterSpacing="0.01"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/danger"
            app:strokeWidth="1dp"
            app:cornerRadius="10dp"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>