<?xml version="1.0" encoding="utf-8"?>
<!--  item_blocked_domain.xml  -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/bg_surface"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="50dp"
                android:layout_height="25dp"
                app:cardCornerRadius="9dp"
                app:cardBackgroundColor="@color/danger_bg"
                app:cardElevation="0dp"
                android:layout_marginEnd="2dp">

                <ImageView
                    android:layout_width="90dp"
                    android:layout_height="65dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_stop" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvDomain"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:ellipsize="middle"
                android:maxLines="1"
                tools:text="paypal-secure-login.xyz"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Blocked"
                android:textSize="11sp"
                android:textColor="@color/danger"
                app:chipBackgroundColor="@color/danger_bg"
                app:chipCornerRadius="8dp"
                app:chipStrokeColor="@color/danger"
                app:chipStrokeWidth="1dp"
                app:chipMinHeight="26dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="42dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tvTimeAgo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                tools:text="Blocked 2 minutes ago"/>

            <TextView
                android:id="@+id/tvCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/danger"
                tools:text="3×"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAllow"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Allow 5 min"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:textColor="@color/warning"
                app:icon="@drawable/ic_shield_check"
                app:iconGravity="start"
                app:iconPadding="6dp"
                app:iconSize="15dp"
                app:iconTint="@color/warning"
                app:strokeColor="@color/warning"
                app:strokeWidth="1dp"
                app:cornerRadius="10dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBlock"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:text="Block Again"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:textColor="@color/danger"
                app:icon="@drawable/ic_stop"
                app:iconGravity="start"
                app:iconPadding="6dp"
                app:iconSize="15dp"
                app:iconTint="@color/danger"
                app:strokeColor="@color/danger"
                app:strokeWidth="1dp"
                app:cornerRadius="10dp"
                android:visibility="gone"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
