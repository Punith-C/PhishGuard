<?xml version="1.0" encoding="utf-8"?>
<!--  item_blocked_url.xml  —  used by BlockedUrlsAdapter  -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/bg_surface"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="32dp"
                android:layout_height="32dp"
                app:cardCornerRadius="9dp"
                app:cardBackgroundColor="@color/danger_bg"
                app:cardElevation="0dp"
                android:layout_marginEnd="10dp">
                <ImageView
                    android:layout_width="47dp"
                    android:layout_height="58dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_stop"/>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvDomain"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:ellipsize="middle"
                android:maxLines="1"
                tools:text="paypal-secure-login.xyz"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Blocked"
                android:textSize="11sp"
                android:textColor="@color/danger"
                app:chipBackgroundColor="@color/danger_bg"
                app:chipCornerRadius="8dp"
                app:chipStrokeColor="@color/danger"
                app:chipStrokeWidth="1dp"
                app:chipMinHeight="26dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvExtraInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="42dp"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:layout_marginBottom="14dp"
            tools:text="Blocked — DNS query dropped"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAllow5Min"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginEnd="03dp"
                android:text="Extend 5 min"
                android:textAllCaps="false"
                android:textColor="@color/cyan_primary"
                android:textSize="12sp"
                app:cornerRadius="10dp"
                app:icon="@drawable/ic_calendar"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconSize="18dp"
                app:iconTint="@null"
                app:strokeColor="@color/stroke"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPermanent"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginEnd="3dp"
                android:text="Always Allow"
                android:textAllCaps="false"
                android:textColor="@color/success"
                android:textSize="12sp"
                app:cornerRadius="10dp"
                app:icon="@drawable/ic_shield_check"
                app:iconGravity="textStart"
                app:iconPadding="3dp"
                app:iconSize="18dp"
                app:iconTint="@null"
                app:strokeColor="@color/success"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRevoke"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Remove"
                android:textSize="10sp"
                android:textAllCaps="false"
                android:textColor="@color/danger"
                app:icon="@drawable/ic_stop"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconSize="18dp"
                app:iconTint="@null"
                app:strokeColor="@color/danger"
                app:strokeWidth="1dp"
                app:cornerRadius="10dp"/>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>